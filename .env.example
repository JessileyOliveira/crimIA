# ─── Groq (gratuito) ──────────────────────────────────────────────────────────
# Obtenha sua chave em: https://console.groq.com/keys
# Usado como fallback se o usuário não fornecer a própria chave
GROQ_API_KEY=gsk_...

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql://crimia:crimia_secret@localhost:5432/crimiadb
# Railway: gerado automaticamente ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://crimia:crimia_secret@localhost:5432/crimiadb

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Railway: gerado automaticamente ao adicionar o plugin Redis
REDIS_URL=redis://localhost:6379

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Desenvolvimento local: URL do Vite dev server
# Railway: não precisa definir (frontend é servido pelo backend)
FRONTEND_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere um valor seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_forte_em_producao
